---
import { site } from "../content/site";

const doubled = [...site.skills, ...site.skills];
---

<section id="skills" class="relative overflow-hidden border-y border-white/5 py-20">
  <div class="fluid-container">
    <span data-reveal="left" class="fluid-label font-mono uppercase tracking-[0.3em] text-coral">03 — Skills</span>
    <h2 data-reveal data-delay="1" class="fluid-section-heading mt-4 font-display font-bold text-cream">
      Tools & technologies
    </h2>
  </div>

  <div data-reveal="fade" data-delay="2" class="relative mt-12">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-ink to-transparent"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-ink to-transparent"></div>

    <div class="marquee-track flex w-max gap-6">
      {
        doubled.map((skill) => (
          <span
            class="fluid-small flex shrink-0 items-center gap-3 rounded-full border border-white/5 bg-ink-light px-6 py-3 font-mono text-cream-muted"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-teal"></span>
            {skill}
          </span>
        ))
      }
    </div>
  </div>

  <div class="fluid-container mt-20">
    <h3 data-reveal class="fluid-label font-mono uppercase tracking-[0.3em] text-cream-muted">Experience</h3>
    <div class="mt-8 space-y-0">
      {
        site.experience.map((item, i) => (
          <div data-reveal data-delay={String(Math.min(i + 1, 4))} class="grid gap-4 border-t border-white/5 py-8 sm:grid-cols-12 sm:gap-8">
            <div class="sm:col-span-3">
              <p class="fluid-label font-mono uppercase tracking-widest text-cream-muted">
                {item.period}
              </p>
            </div>
            <div class="sm:col-span-4">
              <h4 class="fluid-small font-display font-bold text-cream">{item.role}</h4>
              <p class="fluid-card-body mt-1 text-teal">{item.company}</p>
            </div>
            <div class="sm:col-span-5">
              <p class="fluid-card-body text-cream-muted">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
