---
import { site } from "../content/site";
---

<section id="about" class="relative py-32">
  <div class="fluid-container">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <span data-reveal="left" class="fluid-label font-mono uppercase tracking-[0.3em] text-coral">01 — About</span>
        <h2 data-reveal data-delay="1" class="fluid-section-heading mt-4 font-display font-bold leading-tight text-cream">
          {site.about.headline}
        </h2>
      </div>

      <div class="lg:col-span-5">
        <div class="fluid-section-body space-y-6 leading-relaxed text-cream-muted">
          {
            site.about.paragraphs.map((p, i) => (
              <p data-reveal data-delay={String(i + 2)}>{p}</p>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-1">
          {
            site.about.stats.map((stat, i) => (
              <div data-reveal="scale" data-delay={String(i + 2)} class="rounded-2xl border border-white/5 bg-ink-light p-6">
                <p class="fluid-card-heading font-display font-bold text-teal">{stat.value}</p>
                <p class="fluid-label mt-1 font-mono uppercase tracking-widest text-cream-muted">
                  {stat.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
