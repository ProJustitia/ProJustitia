---
import { site } from "../content/site";
---

<section id="about" class="relative py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <span class="font-mono text-xs uppercase tracking-[0.3em] text-coral">01 — About</span>
        <h2 class="mt-4 font-display text-4xl font-bold leading-tight text-cream sm:text-5xl">
          {site.about.headline}
        </h2>
      </div>

      <div class="lg:col-span-5">
        <div class="space-y-6 text-lg leading-relaxed text-cream-muted">
          {
            site.about.paragraphs.map((p) => (
              <p>{p}</p>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-1">
          {
            site.about.stats.map((stat) => (
              <div class="rounded-2xl border border-white/5 bg-ink-light p-6">
                <p class="font-display text-3xl font-bold text-teal">{stat.value}</p>
                <p class="mt-1 font-mono text-xs uppercase tracking-widest text-cream-muted">
                  {stat.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
