---
import { site } from "../content/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-10">
  <div data-reveal="fade" class="fluid-container flex flex-col items-center justify-between gap-4 sm:flex-row">
    <p class="fluid-label font-mono text-cream-muted">
      © {year} {site.name}. Crafted with Astro & Tailwind.
    </p>
    <a
      href={site.social.instagram}
      target="_blank"
      rel="noopener noreferrer"
      class="fluid-label font-mono uppercase tracking-widest text-cream-muted transition-colors hover:text-teal"
    >
      @firmanftrah
    </a>
  </div>
</footer>
